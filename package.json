{
    "name": "ml-cyoa-workspace",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.32.0",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "dev":          "pnpm --filter publishing-party dev",
        "build":        "pnpm --filter editor build && pnpm --filter publishing-party build",
        "preview":      "pnpm --filter publishing-party preview",
        "deploy":       "pnpm --filter publishing-party deploy",
        "lint":         "pnpm -r lint",
        "lint:fix":     "pnpm -r lint:fix",
        "test":         "pnpm -r test",
        "test:watch":   "pnpm --filter editor test:watch",
        "test:coverage": "pnpm --filter editor test:coverage"
    },
    "devDependencies": {
        "@eslint/js":               "^9.39.4",
        "eslint-plugin-react":      "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "typescript-eslint":        "^8.59.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": ["esbuild"]
    }
}
